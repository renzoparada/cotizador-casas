# URL de conexión a Postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cotizador?schema=public"

# Secreto para firmar las sesiones (generar con: openssl rand -base64 32)
AUTH_SECRET="reemplazar-con-un-valor-aleatorio-largo"

# URL pública donde corre la app (usada por NextAuth para construir callbacks)
NEXTAUTH_URL="http://localhost:3000"

# Credenciales del usuario admin que crea `npm run db:seed`.
# Cambiá la contraseña luego de tu primer ingreso.
ADMIN_EMAIL="admin@cotizador-casas.local"
ADMIN_PASSWORD="reemplazar-con-una-contraseña-segura"
